<%- include('partials/header') %>

<main>
  <h1>Edit Project</h1>

  <form action="/edit-project/<%= project.project_id %>" method="POST">
    
    <label>Title</label>
    <input type="text" name="title" value="<%= project.title %>" required>

    <label>Description</label>
    <textarea name="description" required><%= project.description %></textarea>

    <label>Start Date</label>
    <input type="date" name="start_date" 
        value="<%= project.start_date ? project.start_date.toISOString().split('T')[0] : '' %>" 
        required>

    <label>End Date</label>
    <input type="date" name="end_date" 
        value="<%= project.end_date ? project.end_date.toISOString().split('T')[0] : '' %>" 
        required>

    <label>Location</label>
    <input type="text" name="location" value="<%= project.location %>" required>

    <label>Organization</label>
    <select name="organization_id">
      <% organizations.forEach(org => { %>
        <option 
          value="<%= org.organization_id %>"
          <%= org.organization_id === project.organization_id ? 'selected' : '' %>
        >
          <%= org.name %>
        </option>
      <% }) %>
    </select>

    <button type="submit">Update Project</button>
  </form>

</main>

<%- include('partials/footer') %>