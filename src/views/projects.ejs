<%- include('partials/header') %>

<h1><%= title %></h1>

<h2>Upcoming Service Projects</h2>

<ul>
    <% projects.forEach(project => { %>
        <li>
            <!-- Project title links to project details -->
            <a href="/project/<%= project.project_id %>"><strong><%= project.title %></strong></a>
            , <%= project.description %>
            <!-- Link to organization details -->
            (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
        </li>
    <% }) %>
</ul>

<%- include('partials/footer') %>