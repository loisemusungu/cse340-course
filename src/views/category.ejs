<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>

  <h2>Projects in "<%= category.name %>"</h2>

  <% if (category.projects.length === 0) { %>
    <p>No projects in this category yet.</p>
  <% } else { %>
    <ul>
      <% category.projects.forEach(project => { %>
        <li>
          <a href="/project/<%= project.project_id %>"><%= project.title %></a>
          (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
        </li>
      <% }) %>
    </ul>
  <% } %>

  <p><a href="/categories">Back to Categories</a></p>
  <!-- Edit and Add buttons -->
  <p><a href="/edit-category/<%= category.category_id %>">Edit Category</a></p>
  <p><a href="/new-category">Add Category</a></p>
  
</main>

<%- include('partials/footer') %>